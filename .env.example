# Copy this file to .env and fill in your values
# NEVER commit .env to git

# PostgreSQL connection
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/uk_climate
DATABASE_URL_SYNC=postgresql://postgres:yourpassword@localhost:5432/uk_climate

# Admin API key — used for write operations if no key is stored in the DB
ADMIN_API_KEY=change-me-in-production

# Optional: Redis for caching analytics responses (leave blank to disable cache)
# REDIS_URL=redis://localhost:6379
